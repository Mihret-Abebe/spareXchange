    {
      "name": "9. Report Management",
      "item": [
        {
          "name": "Get All Reports (Paginated)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/reports?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "reports"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "Get all reports with pagination"
          }
        },
        {
          "name": "Get Reports by Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/reports?status=pending",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "reports"],
              "query": [
                {
                  "key": "status",
                  "value": "pending"
                }
              ]
            },
            "description": "Get all pending reports"
          }
        },
        {
          "name": "Get Reports by Target Model",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/reports?targetModel=Listing",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "reports"],
              "query": [
                {
                  "key": "targetModel",
                  "value": "Listing"
                }
              ]
            },
            "description": "Get all reports targeting listings"
          }
        },
        {
          "name": "Get Report by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/reports/{{report_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "reports", "{{report_id}}"]
            },
            "description": "Get detailed information about a specific report"
          }
        },
        {
          "name": "Get Report Statistics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/reports/stats",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "reports", "stats"]
            },
            "description": "Get report statistics including reports by status, target, reason, and average resolution time"
          }
        },
        {
          "name": "Update Report Status - Resolve",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"resolved\",\n  \"moderatorNote\": \"Investigated and confirmed violation. Listing removed.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/reports/{{report_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "reports", "{{report_id}}"]
            },
            "description": "Update report status to resolved with moderator note"
          }
        },
        {
          "name": "Update Report Status - Dismiss",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"dismissed\",\n  \"moderatorNote\": \"No violation found after investigation.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/reports/{{report_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "reports", "{{report_id}}"]
            },
            "description": "Update report status to dismissed with moderator note"
          }
        },
        {
          "name": "Update Report Status - Remove Listing",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"resolved\",\n  \"moderatorNote\": \"Listing violates community guidelines.\",\n  \"action\": \"remove_listing\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/reports/{{report_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "reports", "{{report_id}}"]
            },
            "description": "Resolve report and remove the reported listing"
          }
        },
        {
          "name": "Update Report Status - Ban User",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"resolved\",\n  \"moderatorNote\": \"User violated terms of service multiple times.\",\n  \"action\": \"ban_user\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/reports/{{report_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "reports", "{{report_id}}"]
            },
            "description": "Resolve report and ban the reported user"
          }
        },
        {
          "name": "Update Report Status - Warn User",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"reviewed\",\n  \"moderatorNote\": \"First violation. User has been warned.\",\n  \"action\": \"warn_user\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/reports/{{report_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "reports", "{{report_id}}"]
            },
            "description": "Mark report as reviewed and send warning to user"
          }
        },
        {
          "name": "Delete Report",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/reports/{{report_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "reports", "{{report_id}}"]
            },
            "description": "Delete a report (admin cleanup)"
          }
        }
      ]
    },
    {
      "name": "10. Admin Jobs",
      "item": [
        {
          "name": "Run Saved Search Alerts Job",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"limitSearches\": 100,\n  \"limitListingsPerSearch\": 5\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/jobs/saved-search-alerts",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "jobs", "saved-search-alerts"]
            },
            "description": "Manually trigger the saved search alerts processing job"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "your_jwt_token_here",
      "type": "string"
    },
    {
      "key": "report_id",
      "value": "report_id_here",
      "type": "string"
    }
  ]
}
