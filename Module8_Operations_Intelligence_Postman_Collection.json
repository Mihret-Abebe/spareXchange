{
  "info": {
    "name": "Module 8 - Operations & Intelligence",
    "description": "Comprehensive API testing collection for analytics, reporting, and operational intelligence features",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Platform Statistics",
      "item": [
        {
          "name": "Get Basic Platform Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/stats",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "stats"]
            },
            "description": "Get basic platform statistics (total users, listings, exchanges)"
          }
        },
        {
          "name": "Get Comprehensive Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/analytics/comprehensive",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "analytics", "comprehensive"]
            },
            "description": "Get comprehensive platform statistics with breakdowns and recent activity"
          }
        }
      ]
    },
    {
      "name": "2. Time-Series Analytics",
      "item": [
        {
          "name": "Get Daily Trends (Last 30 Days)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/analytics/trends?period=daily&days=30",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "analytics", "trends"],
              "query": [
                {
                  "key": "period",
                  "value": "daily"
                },
                {
                  "key": "days",
                  "value": "30"
                }
              ]
            },
            "description": "Get daily trends for users, listings, and exchanges over last 30 days"
          }
        },
        {
          "name": "Get Weekly Trends (Last 12 Weeks)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/analytics/trends?period=weekly&days=84",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "analytics", "trends"],
              "query": [
                {
                  "key": "period",
                  "value": "weekly"
                },
                {
                  "key": "days",
                  "value": "84"
                }
              ]
            },
            "description": "Get weekly trends for the last 12 weeks"
          }
        },
        {
          "name": "Get Monthly Trends (Last 12 Months)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/analytics/trends?period=monthly&days=365",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "analytics", "trends"],
              "query": [
                {
                  "key": "period",
                  "value": "monthly"
                },
                {
                  "key": "days",
                  "value": "365"
                }
              ]
            },
            "description": "Get monthly trends for the last 12 months"
          }
        }
      ]
    },
